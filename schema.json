{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "company_name": { "type": "string" },
    "summary": { "type": "string" },
    "metrics": {
      "type": "object",
      "properties": {
        "compensation": { "type": "integer", "minimum": 1, "maximum": 10 },
        "workload": { "type": "integer", "minimum": 1, "maximum": 10 },
        "culture": { "type": "integer", "minimum": 1, "maximum": 10 },
        "stability": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "tech_stack": { "type": "array", "items": { "type": "string" } },
    "verdict": { "type": "string" }
  },
  "required": ["company_name", "summary", "metrics", "tech_stack", "verdict"]
}
